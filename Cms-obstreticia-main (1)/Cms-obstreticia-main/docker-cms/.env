# ─────────────────────────────────────────────────────────────────
# Variables de entorno — CMS Obstetricia
# ¡NUNCA subas este archivo a GitHub!  Está en .gitignore.
# Copia este archivo como .env y completa los valores reales.
# ─────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────
# Contraseña de SQL Server (mínimo 8 chars, mayúscula, número y símbolo)
DB_PASSWORD=CambiarEsto_2026!

# ── JWT ───────────────────────────────────────────────────────────
# Clave secreta para firmar tokens (mínimo 32 caracteres)
JWT_SECRET=CAMBIAR_POR_CLAVE_SECRETA_MIN_32_CHARS_AQUI
JWT_ISSUER=CMSVinculacion.Api
JWT_AUDIENCE=CMSVinculacion.Client

# ── Protector de datos ────────────────────────────────────────────
LLAVE_PROTECTOR=CMSVinculacion_LlaveProtector_2026

# ── CORS ──────────────────────────────────────────────────────────
# En producción: tu dominio real, p.ej. https://cms.ug.edu.ec
CORS_ORIGIN=http://localhost

# ── Entorno de ASP.NET ────────────────────────────────────────────
# Valores posibles: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Production
